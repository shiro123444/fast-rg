MAIL_DOMAIN=your-domain.com
MAIL_WORKER_BASE=https://mail-worker.example.com
MAIL_ADMIN_PASSWORD=your_mail_admin_password
TOKEN_OUTPUT_DIR=
CLI_PROXY_AUTHS_DIR=

# Proxy options
PROXY=http://127.0.0.1:7897
# PROXY_FILE=proxies.txt

# Batch options
# BATCH_COUNT=10
# BATCH_THREADS=1

# Email mode: luckmail / gmail / hotmail007 / file / cf
EMAIL_MODE=luckmail
GMAIL_BASE=your_gmail_base
# ACCOUNTS_FILE=accounts.txt

# CPA upload config
CPA_API_URL=http://127.0.0.1:8317
CPA_API_KEY=your_cpa_api_key

# Hotmail007 config
HOTMAIL007_API_URL=https://gapi.hotmail007.com
HOTMAIL007_API_KEY=your_hotmail007_api_key
HOTMAIL007_MAIL_TYPE=outlook-premium
HOTMAIL007_MAIL_MODE=imap

# LuckMail config
LUCKMAIL_SDK_PATH=/path/to/auto_reg/core
LUCKMAIL_BASE_URL=https://mails.example.com
LUCKMAIL_API_KEY=your_luckmail_api_key
LUCKMAIL_PROJECT_CODE=openai
LUCKMAIL_EMAIL_TYPE=ms_imap
LUCKMAIL_DOMAIN=hotmail.com
